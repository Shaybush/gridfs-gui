# Frontend (Vite)
# Set for local dev; leave empty for Docker (nginx proxies /api)
VITE_API_URL=http://localhost:8000

# Server
PORT=8000
HOST=0.0.0.0
DEBUG=false
APP_NAME=gridfs-gui
CORS_ORIGINS=*

# Required: Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-256-bit-hex-key-here

# Persistent storage directory (connections database)
DATA_DIR=./data
